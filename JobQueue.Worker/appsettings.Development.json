{
  "ConnectionStrings": {
    "Database": "Host=localhost:5432;Username=postgres;Password=postgres;Database=postgres",
    "Redis": "localhost:6379"
  },
  "Worker": {
    "MaxJobRetries": 3
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      },
      "Using": [
        "Serilog.Sinks.Console"
      ]
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}